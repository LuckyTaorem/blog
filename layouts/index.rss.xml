{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML -}}
<rss version="2.0" 
     xmlns:atom="http://www.w3.org/2005/Atom"
     xmlns:content="http://purl.org/rss/1.0/modules/content/"
     xmlns:media="http://search.yahoo.com/mrss/">
  <channel>
    <title>{{ .Site.Title }}</title>
    <link>{{ .Site.BaseURL }}</link>
    <description>Recent content on {{ .Site.Title }}</description>
    <atom:link href="{{ .Permalink }}index.xml" rel="self" type="application/rss+xml" />
    
    {{ range first 20 (where .Site.RegularPages "Section" "posts") }}
    {{ if not .Params.noSitemap }}
    <item>
      <title><![CDATA[{{ .Title | safeHTML }}]]></title>
      <link>{{ .Permalink }}</link>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</pubDate>
      <guid>{{ .Permalink }}</guid>
      
      {{ with .Params.categories }}{{ range . }}<category><![CDATA[{{ . | safeHTML }}]]></category>{{ end }}{{ end }}
      {{ with .Params.tags }}{{ range . }}<category><![CDATA[{{ . | safeHTML }}]]></category>{{ end }}{{ end }}

      {{/* 🖼️ FEATURED IMAGES */}}
      {{ $imgStr := .Params.thumbnail | default (index .Params.images 0) }}
      {{ $imgHtml := "" }}
      {{ if $imgStr }}
        {{ $res := resources.Get $imgStr }}
        {{ if $res }}
          {{ $optimized := $res.Resize "800x webp q80" }}
          <media:content url="{{ $optimized.Permalink }}" medium="image" type="image/webp" />
          <enclosure url="{{ $optimized.Permalink }}" type="image/webp" length="0" />
          {{ $imgHtml = printf "<p><img src=\"%s\" alt=\"%s\" /></p>" $optimized.Permalink .Title }}
        {{ else }}
          <media:content url="{{ $imgStr | absURL }}" medium="image" />
          <enclosure url="{{ $imgStr | absURL }}" type="image/jpeg" length="0" />
          {{ $imgHtml = printf "<p><img src=\"%s\" alt=\"%s\" /></p>" ($imgStr | absURL) .Title }}
        {{ end }}
      {{ end }}

      {{/* 🧹 REGEX CLEANUP PIPELINE */}}
      {{ $cleanContent := .Content }}
      
      {{/* 1. Strip the messy heading anchor links added by Hugo */}}
      {{ $cleanContent = $cleanContent | replaceRE "(?is)<a[^>]*aria-labelledby[^>]*>.*?</a>" "" }}
      
      {{/* 2. Strip all inline SVGs (like the FontAwesome link icons) */}}
      {{ $cleanContent = $cleanContent | replaceRE "(?is)<svg.*?</svg>" "" }}
      
      {{/* 3. Strip lingering HTML comments */}}
      {{ $cleanContent = $cleanContent | replaceRE "(?is)<!--.*?-->" "" }}
      
      {{/* 4. Fix ]]> inside code blocks using LITERAL string replacement, not Regex */}}
      {{ $cleanContent = replace $cleanContent "]]>" "]]]]><![CDATA[>" }}

      {{/* 📝 FULL ENCODED CONTENT (Now inside CDATA so it renders as visual text) */}}
      <content:encoded><![CDATA[{{ $imgHtml | safeHTML }}{{ $cleanContent | safeHTML }}]]></content:encoded>
      
      {{/* 🚨 Clean Description */}}
      {{ $cleanSummary := .Summary | plainify | replaceRE "&nbsp;" " " }}
      {{ $cleanSummary = replace $cleanSummary "]]>" "]]]]><![CDATA[>" }}
      <description><![CDATA[{{ $cleanSummary | safeHTML }}]]></description>
    </item>
    {{ end }}
    {{ end }}
  </channel>
</rss>