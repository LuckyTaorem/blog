{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML -}}
{{- printf "<?xml-stylesheet type=\"text/xsl\" href=\"%s\"?>" ("sitemap.xsl" | absURL) | safeHTML -}}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <!-- Include the Homepage natively -->
  <url>
    <loc>{{ .Site.BaseURL }}</loc>
    <changefreq>daily</changefreq>
    <priority>1.0</priority>
  </url>
  <!-- Loop through all regular pages that are NOT posts -->
  {{ range (where .Site.RegularPages "Section" "!=" "posts") }}
  <url>
    <loc>{{ .Permalink }}</loc>
    {{ if not .Lastmod.IsZero }}<lastmod>{{ .Lastmod.Format "2006-01-02T15:04:05-07:00" }}</lastmod>{{ end }}
    <changefreq>monthly</changefreq>
    <priority>0.6</priority>
  </url>
  {{ end }}
</urlset>