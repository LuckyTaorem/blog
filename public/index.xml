			<item>
				<title>About Us</title>
				<link>http://localhost:1313/blog/about/</link>
				<pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
				<guid>http://localhost:1313/blog/about/</guid>
				<description>&lt;div class=&#34;row align-items-center mt-4&#34;&gt;&#xD;&#xA;  &lt;div class=&#34;col-md-8 offset-md-2 text-center&#34;&gt;&#xD;&#xA;    &lt;h1 class=&#34;fw-bold mb-4 text-body&#34;&gt;Behind the Code&lt;/h1&gt;&#xD;&#xA;    &lt;p class=&#34;lead text-body-secondary mb-5&#34;&gt;We are a next-generation technology publication powered entirely by Artificial Intelligence.&lt;/p&gt;&#xD;&#xA;  &lt;/div&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;div class=&#34;row&#34;&gt;&#xD;&#xA;  &lt;div class=&#34;col-md-6 mb-4&#34;&gt;&#xD;&#xA;    &lt;div class=&#34;card h-100 border-0 shadow-sm bg-body-tertiary&#34;&gt;&#xD;&#xA;      &lt;div class=&#34;card-body p-4&#34;&gt;&#xD;&#xA;        &lt;h3 id=&#34;our-mission&#34; class=&#34;h4 fw-bold text-body&#34;&gt;Our Mission&lt;/h3&gt;&#xD;&#xA;        &lt;p class=&#34;text-body-secondary mt-3&#34;&gt;To aggregate, analyze, and deliver the most important technology news from around the globe. We strip away the fluff and deliver comprehensive, deep-dive articles on the topics that matter.&lt;/p&gt;&#xD;&#xA;      &lt;/div&gt;&#xD;&#xA;    &lt;/div&gt;&#xD;&#xA;  &lt;/div&gt;&#xD;&#xA;  &lt;div class=&#34;col-md-6 mb-4&#34;&gt;&#xD;&#xA;    &lt;div class=&#34;card h-100 border-0 shadow-sm bg-body-tertiary&#34;&gt;&#xD;&#xA;      &lt;div class=&#34;card-body p-4&#34;&gt;&#xD;&#xA;        &lt;h3 id=&#34;how-it-works&#34; class=&#34;h4 fw-bold text-body&#34;&gt;How It Works&lt;/h3&gt;&#xD;&#xA;        &lt;p class=&#34;text-body-secondary mt-3&#34;&gt;Our proprietary automation engine scans top publishers like TechCrunch and Wired every morning. It utilizes advanced Large Language Models (LLMs) to write unique, heavily researched articles completely on autopilot.&lt;/p&gt;</description>
			</item>
